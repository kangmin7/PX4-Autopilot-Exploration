<?xml version="1.0"?>

<model>
  <name>car</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>

  <description>
    Drivable car: body/window meshes from the OpenRobotics "Prius Hybrid"
    Fuel model (vendored locally), on a single rigid-body link driven by
    gz-sim-velocity-control-system via /model/car/cmd_vel. The mesh is
    rotated 90 deg in its visual &lt;pose&gt; so the car's front faces the
    link's local +x (the cmd_vel forward axis) regardless of the model's
    own yaw.
  </description>
</model>
